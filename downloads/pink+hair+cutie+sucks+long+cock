<script>
    /**
     * Shows the advanced age verification modal if required.
     * This function can be called from any event handler, especially from video player controls.
     *
     * @returns {boolean} - Whether the modal was shown
     */
    function showAdvancedAgeVerification() {
        // Get the cookie to check if age verification is required
        const av = getCookie('av');
        if (!av) {
            return false;
        }

        const [avType, avRequired, avGuest] = av.split(':');
        // True is a guest that needs to verify their age, in case of False, it's a registered user that needs to verify their age
        const isAvGuest = avGuest === 'True';

        // Only show for advanced verification and when required
        if (avType !== 'advanced' || avRequired !== 'True') {
            return false;
        }

        // Disable scrolling
        document.body.classList.add('fixed', 'h-full', 'w-full');

        const advancedAvWrapper = document.getElementById('advanced-av');
        if (advancedAvWrapper) {
            advancedAvWrapper.style.display = 'flex';
        }

        if (isAvGuest) {
            showAvRegistrationModal();
            return true;
        } else {
            const avVerification = document.getElementById('av-verification');
            if (avVerification) {
                avVerification.style.display = 'flex';

                if (window.dataLayer) {
                    window.dataLayer.push({
                        event: 'GA4 - Generic Event',
                        event_name: 'av_popup',
                    });
                }
                return true;
            }
        }

        return false;
    }

    function showAvRegistrationModal() {
        const container = document.getElementById('register-age-verification');
        container.innerHTML = `
            <div class="fixed inset-0 z-1100 flex h-screen items-center justify-center">
                <div class="spinner"></div>
            </div>
        `;
        container.style.display = 'flex';

        $.ajax({
            type: 'GET',
            url: '/users/av-registration',
            cache: false,
        }).done(function (data) {
            $(container).replaceWith(data);
            document.getElementById('register-age-verification').style.display = 'flex';
        }).fail(function (error) {
            console.error('Age verification modal failed:', error);
        });

        dataLayer.push({
            event: 'GA4 - Generic Event',
            event_name: 'signup_popup',
        });
    }
</script>


    <script>
        showAdvancedAgeVerification();
    </script>
